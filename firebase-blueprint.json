{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Entry": {
      "title": "Journal Entry",
      "description": "Daily thoughts and reflections",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "mood": { "type": "string" },
        "summary": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "type": { "type": "string", "enum": ["questionnaire", "diary", "chat"] },
        "isNegative": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "createdAt"]
    },
    "Summary": {
      "title": "Daily Summary",
      "description": "Aggregated summary of a user's day",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "moodTags": { "type": "array", "items": { "type": "string" } },
        "keyEvents": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" } } } },
        "doctorNote": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "Entry",
      "description": "User journal entries and reflections"
    },
    "/users/{userId}/summaries/{summaryId}": {
      "schema": "Summary",
      "description": "User daily multi-record aggregations"
    }
  }
}
